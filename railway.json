{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn -DskipTests package"
  },
  "deploy": {
    "startCommand": "sh -c 'java -jar target/*.jar'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
